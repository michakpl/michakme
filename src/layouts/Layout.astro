---
import '../styles/global.css';

interface Props {
  title?: string;
  isHome?: boolean;
  activePath?: string;
}

const { title = "Minimalist personal page", isHome = false, activePath = "/" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    {!isHome && (
      <header class="site-header px-6 py-6">
        <nav class="max-w-2xl mx-auto flex items-center justify-between">
          <div>
            <a href="/" class="nav-home tracking-tight transition-colors">
              Michak's
            </a>
            <p class="nav-subtitle mt-1">
              space for notes
            </p>
          </div>
          <div class="flex gap-6">
            <a
              href="/blog"
              class="text-sm transition-colors nav-link"
              data-active={activePath.startsWith('/blog') ? 'true' : 'false'}
            >
              blog
            </a>
            <a
              href="/about"
              class="text-sm transition-colors nav-link"
              data-active={activePath === '/about' ? 'true' : 'false'}
            >
              about
            </a>
          </div>
        </nav>
      </header>
    )}
    <main class="max-w-2xl mx-auto px-6 py-12">
      <slot />
    </main>
    <footer class="max-w-2xl mx-auto px-6 pb-12">
      <p class="footer-text">
        &copy; {new Date().getFullYear()} Michak
      </p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
  }

  .nav-home {
    color: var(--foreground);
    text-decoration: none;
  }

  .nav-home:hover {
    color: var(--muted);
  }

  .nav-subtitle {
    font-family: 'Montserrat Alternates', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.01em;
    color: var(--muted);
  }

  .nav-link {
    text-decoration: none;
    color: var(--muted);
  }

  .nav-link[data-active="true"] {
    color: var(--foreground);
  }

  .nav-link:hover {
    color: var(--foreground);
  }

  .footer-text {
    font-size: 0.75rem;
    color: var(--very-muted);
  }
</style>
