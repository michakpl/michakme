---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Michak's" isHome={true}>
  <div class="flex flex-col gap-10 pt-16 pb-8">
    <div>
      <h1 class="home-title tracking-tight">
        Michak's
      </h1>
      <p class="home-subtitle mt-3">
        space for notes
      </p>
    </div>

    <div class="flex flex-col gap-2 pt-2">
      <a href="/blog" class="nav-link flex items-center gap-2 w-fit transition-colors">
        <span class="nav-line"></span>
        blog
      </a>
      <a href="/about" class="nav-link flex items-center gap-2 w-fit transition-colors">
        <span class="nav-line"></span>
        about
      </a>
    </div>
  </div>
</Layout>

<style>
  .home-title {
    font-family: 'Montserrat Alternates', sans-serif;
    font-size: clamp(3rem, 10vw, 6rem);
    line-height: 1.05;
    font-weight: 400;
    color: var(--foreground);
  }

  .home-subtitle {
    font-family: 'Montserrat Alternates', sans-serif;
    font-size: 1.1rem;
    letter-spacing: 0.01em;
    color: var(--muted);
  }

  .nav-link {
    color: var(--foreground);
    font-size: 1rem;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--muted);
  }

  .nav-line {
    display: inline-block;
    height: 1px;
    background-color: var(--very-muted);
    width: 1rem;
    transition: width 200ms;
  }

  .nav-link:hover .nav-line {
    width: 1.5rem;
  }
</style>
