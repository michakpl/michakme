---
import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'about');
const { Content } = await render(entry!);

const interests = entry?.data.interests ?? [];
const elsewhere = entry?.data.elsewhere ?? [];
---

<Layout title="About — Michak's" activePath="/about">
  <h1
    class="mb-10 tracking-tight"
    style="font-size: 1.5rem; font-weight: 400; font-family: 'Montserrat Alternates', sans-serif; color: #2E2A26;"
  >
    About
  </h1>

  <div class="flex flex-col gap-5 about-prose" style="font-size: 1rem; line-height: 1.75; color: #5C5650;">
    <Content />

    <div class="pt-4">
      <h2
        class="mb-4 tracking-tight"
        style="font-size: 1rem; font-weight: 500; font-family: 'Montserrat Alternates', sans-serif; color: #2E2A26;"
      >
        Things I'm currently interested in
      </h2>
      <ul style="list-style: none; padding: 0;" class="flex flex-col gap-2">
        {interests.map((item) => (
          <li class="flex gap-3" style="color: #6B6560;">
            <span class="select-none" style="color: #C0B9B2;">—</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="pt-4">
      <h2
        class="mb-4 tracking-tight"
        style="font-size: 1rem; font-weight: 500; font-family: 'Montserrat Alternates', sans-serif; color: #2E2A26;"
      >
        Elsewhere
      </h2>
      <ul style="list-style: none; padding: 0;" class="flex flex-col gap-2">
        {elsewhere.map(({ label, href }) => (
          <li class="flex gap-3">
            <span class="select-none" style="color: #C0B9B2;">—</span>
            <a
              href={href}
              class="elsewhere-link transition-colors"
              style="color: #6B6560; text-decoration: underline; text-decoration-color: #C0B9B2; text-underline-offset: 3px;"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>

<style>
  .elsewhere-link:hover {
    color: #96908A !important;
  }

  .about-prose :global(p) {
    margin: 0;
  }
</style>
