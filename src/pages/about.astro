---
import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'about');
const { Content } = await render(entry!);

const interests = entry?.data.interests ?? [];
const elsewhere = entry?.data.elsewhere ?? [];
---

<Layout title="About — Michak's" activePath="/about">
  <h1 class="page-title mb-10 tracking-tight">
    About
  </h1>

  <div class="flex flex-col gap-5 about-prose">
    <Content />

    <div class="pt-4">
      <h2 class="section-heading mb-4 tracking-tight">
        Things I'm currently interested in
      </h2>
      <ul class="bare-list flex flex-col gap-2">
        {interests.map((item) => (
          <li class="list-item gap-3">
            <span class="dash select-none">—</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="pt-4">
      <h2 class="section-heading mb-4 tracking-tight">
        Elsewhere
      </h2>
      <ul class="bare-list flex flex-col gap-2">
        {elsewhere.map(({ label, href }) => (
          <li class="flex gap-3">
            <span class="dash select-none">—</span>
            <a
              href={href}
              class="elsewhere-link transition-colors"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>

<style>
  .about-prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-soft);
  }

  .section-heading {
    font-size: 1rem;
    font-weight: 500;
    font-family: 'Montserrat Alternates', sans-serif;
    color: var(--foreground);
  }

  .bare-list {
    list-style: none;
    padding: 0;
  }

  .list-item {
    color: var(--text-mid);
  }

  .dash {
    color: var(--very-muted);
  }

  .elsewhere-link {
    color: var(--text-mid);
    text-decoration: underline;
    text-decoration-color: var(--very-muted);
    text-underline-offset: 3px;
  }

  .elsewhere-link:hover {
    color: var(--muted);
  }

  .about-prose :global(p) {
    margin: 0;
  }
</style>
